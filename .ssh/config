Host via-server
  HostName flat-meadow-prod-main-01.tail496cab.ts.net
  User via
  Port 22
  PubkeyAuthentication yes
  IdentityFile ~/.ssh/id_ed25519
  AddKeysToAgent yes

# 1Password SSH agent — platform-aware socket path
Match host * exec "test -e '$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock'"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Match host * exec "test -e '$HOME/.1password/agent.sock'"
  IdentityAgent "~/.1password/agent.sock"
