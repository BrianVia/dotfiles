# Tail follow with default 100 lines, use -l to override (e.g., tf -l 1000 file.log)
tf() {
  local lines=100
  if [[ "$1" == "-l" ]]; then
    lines="$2"
    shift 2
  fi
  tail -f -n "$lines" "$@"
}
