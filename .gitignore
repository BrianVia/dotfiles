# Secrets and credentials - NEVER commit these
.aws/credentials
.aws/sso/
.secret_env_vars
.env
.env.local
.env.*.local

# 1Password
.op/

# SSH keys (config is tracked, keys are NOT)
.ssh/id_*
.ssh/known_hosts*
.ssh/authorized_keys
.ssh/environment-*
!.ssh/config
# Allow vault-encrypted private key and public key (safe to commit)
!.ssh/id_ed25519.vault
!.ssh/id_ed25519.pub

# API keys and tokens
.github/token
.github/config
.github/hosts

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.editor-config

# Node/npm
node_modules/
bun.lock

# Python
__pycache__/
*.py[cod]
*$py.class

# macOS specific
Library/
.config/MacOSXKeychain

# WSL/Linux specific
.wsl2-env

# Local overrides
.local/
.config/local/

# Generated/cached
.cache/
**/cache/
